#include <iostream>
#include <queue>
#include <cstdlib>
#include <ctime>

using namespace std;

struct Node {
    int data;
    Node* left;
    Node* right;

    Node(int value) : data(value), left(nullptr), right(nullptr) {}
};

class BST {
private:
    Node* root;

    // Вспомогательная функция для удаления дерева
    void destroyTree(Node* node) {
        if (node == nullptr) return;
        destroyTree(node->left);
        destroyTree(node->right);
        delete node;
    }

    // Вспомогательная функция для копирования дерева
    Node* copyTree(Node* node) {
        if (node == nullptr) return nullptr;
        Node* newNode = new Node(node->data);
        newNode->left = copyTree(node->left);
        newNode->right = copyTree(node->right);
        return newNode;
    }

    // Поиск минимума
    Node* findMin(Node* node) {
        while (node && node->left != nullptr)
            node = node->left;
        return node;
    }

    // Поиск максимума
    Node* findMax(Node* node) {
        while (node && node->right != nullptr)
            node = node->right;
        return node;
    }

    // Обход в ширину
    void BFS(Node* node) {
        if (node == nullptr) return;

        queue<Node*> q;
        q.push(node);

        while (!q.empty()) {
            Node* current = q.front();
            q.pop();
            cout << current->data << " ";

            if (current->left != nullptr)
                q.push(current->left);
            if (current->right != nullptr)
                q.push(current->right);
        }
    }

    // Обход в высоту (ЛПК)
    void DFS(Node* node) {
        if (node == nullptr) return;

        DFS(node->left);
        DFS(node->right);
        cout << node->data << " ";
        
    }

    void printBST(Node* q, int level) const {
        if (q == nullptr) {
            return;
        }
        printBST(q->right, level + 1);

        //отступы
        for (int i = 0; i < level; i++) {
            cout << "   "; 
        }

        cout << q->data << endl;

        printBST(q->left, level + 1);
    }

public:
    BST() : root(nullptr) {
        cout << "Создано пустое дерево" << endl;
    }

    BST(int arr[], int size) : root(nullptr) {
        cout << "Создание дерева из массива..." << endl;
        for (int i = 0; i < size; i++) {
            insert(arr[i]);
        }
    }

    BST(int count) : root(nullptr) {
        cout << "Создание дерева с " << count << " случайными узлами..." << endl;
        srand(time(0));
        for (int i = 0; i < count; i++) {
            int value = rand() % 100 + 1;
            insert(value);
        }
    }
   
    ~BST() {
        cout << "Удаление дерева" << endl;
        destroyTree(root);
    }

    //#############################################################################################
    //#############################################################################################
    //#############################################################################################

    BST(const BST& other) {
        cout << "Копирование дерева..." << endl;
        root = copyTree(other.root);
    }

    BST& operator=(const BST& other) {
        if (this != &other) {
            destroyTree(root);
            root = copyTree(other.root);
        }
        return *this;
    }
    
    //#############################################################################################
    //#############################################################################################
    //#############################################################################################

    int getMin() {
        Node* minNode = findMin(root);
        return minNode ? minNode->data : -1;
    }

    int getMax() {
        Node* maxNode = findMax(root);
        return maxNode ? maxNode->data : -1;
    }

    bool search(int key) {
        Node* current = root;
        while (current != nullptr) {
            if (current->data == key)
                return true;
            if (key < current->data)
                current = current->left;
            else
                current = current->right;
        }
        return false;
    }

    // Вставка узла
    void insert(int value) {
        if (root == nullptr) {
            root = new Node(value);
            return;
        }

        Node* current = root;
        while (true) {
            if (value < current->data) {
                if (current->left == nullptr) {
                    current->left = new Node(value);
                    return;
                }
                current = current->left;
            }
            else if (value > current->data) {
                if (current->right == nullptr) {
                    current->right = new Node(value);
                    return;
                }
                current = current->right;
            }
            else {
                return;
            }
        }
    }

    // Удаление узла
    void remove(int key) {
        if (root == nullptr) return;

        Node* n = root;
        Node* parent_n = nullptr;
        bool is_left_child = false;

        while (n != nullptr && n->data != key) {
            parent_n = n;
            if (key < n->data) {
                n = n->left;
                is_left_child = true;
            }
            else {
                n = n->right;
                is_left_child = false;
            }
        }

        if (n == nullptr) return;

        Node* rn = nullptr;

        if (n->left == nullptr || n->right == nullptr) {
            rn = (n->left != nullptr) ? n->left : n->right;
        }
        else {
            rn = n->right;

            if (rn->left == nullptr) {
                rn->left = n->left;
            }
            else {
                Node* rp = rn;
                rn = rn->left;
                while (rn->left != nullptr) {
                    rp = rn;
                    rn = rn->left;
                }

                rp->left = rn->right;

                rn->left = n->left;
                rn->right = n->right;
            }
        }

        if (parent_n == nullptr) {
            root = rn;
        }
        else {
            if (is_left_child) {
                parent_n->left = rn;
            }
            else {
                parent_n->right = rn;
            }
        }

        delete n;
    }

    //#############################################################################################
    //#############################################################################################
    //#############################################################################################
    

    // Обход в ширину
    void printBFS() {
        cout << "Обход в ширину: ";
        BFS(root);
        cout << endl;
    }

    // Обход в глубину (ЛПК)
    void printDFS() {
        cout << "Обход ЛПК: ";
        DFS(root);
        cout << endl;
    }

    // Проверка на пустоту
    bool isEmpty() {
        return root == nullptr;
    }
    // Публичный метод для запуска повёрнутого вывода
    void printBST() const {
        if (root == nullptr) {
            cout << "Дерево пустое!" << endl;
            return;
        }
        cout << "\n=== Повёрнутое дерево (корень слева, правое сверху) ===\n";
        printBST(root, 0);
        cout << "=== Конец дерева ===\n";
    }
};

int main() {
    setlocale(LC_ALL, "Russian");

    BST tree;

    int choice, value;

    do {
        cout << "1. Добавить узел" << endl;
        cout << "2. Удалить узел" << endl;
        cout << "3. Поиск узла" << endl;
        cout << "4. Найти минимум" << endl;
        cout << "5. Найти максимум" << endl;
        cout << "6. Обход в ширину" << endl;
        cout << "7. Обход в высоту (ЛПК)" << endl;
        cout << "8. Создать дерево из массива" << endl;
        cout << "9. Создать дерево со случайными значениями" << endl;
        cout << "10. Копировать дерево" << endl;
        cout << "11. Вывести дерево" << endl;
        cout << "0. Выход" << endl;
        cout << "Выбор: ";
        cin >> choice;

        switch (choice) {
        case 1:
            cout << "Введите значение: ";
            cin >> value;
            tree.insert(value);
            cout << "Узел добавлен!" << endl;
            break;

        case 2:
            cout << "Введите значение для удаления: ";
            cin >> value;
            tree.remove(value);
            cout << "Узел удален!" << endl;
            break;

        case 3:
            cout << "Введите значение для поиска: ";
            cin >> value;
            if (tree.search(value))
                cout << "Узел найден!" << endl;
            else
                cout << "Узел не найден!" << endl;
            break;

        case 4:
            if (!tree.isEmpty())
                cout << "Минимум: " << tree.getMin() << endl;
            else
                cout << "Дерево пустое!" << endl;
            break;

        case 5:
            if (!tree.isEmpty())
                cout << "Максимум: " << tree.getMax() << endl;
            else
                cout << "Дерево пустое!" << endl;
            break;

        case 6:
            tree.printBFS();
            break;

        case 7:
            tree.printDFS();
            break;

        case 8: {
            int size;
            cout << "Введите размер массива: ";
            cin >> size;
            int* arr = new int[size];
            cout << "Введите " << size << " элементов: ";
            for (int i = 0; i < size; i++)
                cin >> arr[i];

            tree = BST(arr, size);
            delete[] arr;
            break;
        }

        case 9: {
            int count;
            cout << "Введите количество узлов: ";
            cin >> count;
            tree = BST(count);
            break;
        }

        case 10: {
            BST copyTree = tree;
            cout << "Дерево скопировано!" << endl;
            cout << "Оригинал: ";
            tree.printDFS();
            cout << "Копия: ";
            copyTree.printDFS();
            break;
        }

        case 11:
            tree.printBST();
            break;

        case 0:
            cout << "Выход из программы..." << endl;
            break;

        default:
            cout << "Неверный выбор!" << endl;
        }

    } while (choice != 0);

    return 0;
}

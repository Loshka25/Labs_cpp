class Array {
    int* arr, length;
public:
    // Конструктор с параметрами
    Array(int len = 1, int mode = 1, int range = 10) : length(len) {
        if (len <= 0) length = 1;

        arr = new int[length] {0};
        if (mode <= 0 || mode > 3) {
            cout << "Your mode is incorrect,i choose mode ==1" << endl;
            mode = 1;
        }
        if (mode == 1) {
            srand(time(0));
            for (int i = 0; i < length; i++) {
                arr[i] = rand() % range;
            }
        }
         
        if (mode == 2) {
            srand(time(0));
            arr[0] = rand() % 1000;
            for (int i = 1; i < length; i++) {
                arr[i] = arr[i - 1] + rand() % 1000; // Гарантируем неубывание
                }
        }

        if(mode==3){
            srand(time(0));
            arr[0] = 1000;
            for (int i = length - 1; i > 0; i--) {
                arr[i - 1] = arr[i] + rand() % 1000; // Гарантируем невозрастание
            }
        }
        
    }

    // Конструктор по массиву
    Array(int* A, int len) {
        if (len <= 0) { cout << "Dlina menshe nuzhnoy" << endl; exit(1); }
        length = len;
        arr = new int[length];
        for (int i = 0; i < length; i++) {
            arr[i] = A[i];  // Копируем из внешнего массива
        }
    }

    // Копирующий конструктор
    Array(const Array& other) {
        length = other.length;
        arr = new int[length];
        for (int i = 0; i < length; i++)
            arr[i] = other.arr[i];
    }

    // Деструктор
    ~Array() {
        delete[] arr;
    }

    // Оператор присваивания
    Array& operator=(const Array& other) {
        if (this != &other) {
            delete[] arr;
            length = other.length;
            arr = new int[length];
            for (int i = 0; i < length; i++) {
                arr[i] = other.arr[i];
            }
        }
        return *this;
    }

    int& operator[](int index) {
        if (index < 0 || index >= length) {
            cout << "Index out of bounds" << endl;
            exit(2);
        }
        return arr[index];
    }


    // Проверка на упорядоченность по неубыванию
    bool isSorted() {
        for (int i = 1; i < length; i++) {
            if (arr[i] < arr[i - 1]) {
                return false;
            }
        }
        return true;
    }

bool operator==(Array other) {    
    if (length != other.length)    
        return false;    

    // Создаем копии    
    Array temparr1(*this);  // Используем конструктор копирования класса
    Array temparr2(other); 

    // Сортировка пузырьком для copy1    
    temparr1.HoarSort();
    temparr2.HoarSort();


    // Сравниваем отсортированные массивы    
    bool ravni = true;    
    for (int i = 0; i < length; i++) {    
        if (temparr1[i] != temparr2[i]) {    
            ravni = false;    
            break;    
        }    
    }

    return ravni;    
}    

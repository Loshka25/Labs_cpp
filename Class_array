void HoarSort() {    
    HoarSortRecursive(0, length - 1);    
}    

// вариант Хоар 3    
void HoarSortRecursive(int l, int r) {    
    if (l >= r) {    
        return;    
    }    

    int x = arr[(l + r) / 2];    

    int i = l;    
    int j = r;    

    // Разделение массива на две части    
    while (i <= j) {    
        // Пропускаем элементы, которые меньше медианы слева    
        while (arr[i] < x) {    
            i++;    
        }



        // Пропускаем элементы, которые больше медианы справа    
        while (arr[j] > x) {    
            j--;    
        }    

        // Если нашли пару элементов, которые нужно поменять местами    
        if (i <= j) {    
            // Меняем элементы местами    
            int temp = arr[i];    
            arr[i] = arr[j];    
            arr[j] = temp;    

            // Сдвигаем индексы    
            i++;    
            j--;    
        }    
    }    

    // Рекурсивно сортируем левую часть (если она есть)    
    if (l < j) {    
        HoarSortRecursive(l, j);    
    }    

    // Рекурсивно сортируем правую часть (если она есть)    
    if (i < r) {    
        HoarSortRecursive(i, r);    
    }    
}

void siftDown(int i, int n) {    
    int x = arr[i];  // Сохраняем значение просеиваемого элемента    
    int j;    

    while (2 * i + 1 < n) {  // Пока есть хотя бы один потомок    
        j = 2 * i + 1;   // Левый потомок    

        // Выбираем большего потомка    
        if (j + 1 < n && arr[j] < arr[j + 1]) {    
            j++;    
        }    

        // Если значение просеиваемого элемента уже больше или равно значению потомка    
        if (x >= arr[j]) {    
            break;    
        }    

        // Просеиваем элемент вниз    
        arr[i] = arr[j];    
        i = j;    
    }    

    arr[i] = x;  // Помещаем элемент на его место    
}    
void heapSort() {    
    // 1. Построение пирамиды (кучи)    
    // Начинаем с последнего элемента, у которого есть потомки    
    for (int i = length / 2 - 1; i >= 0; i--) {    
        siftDown(i, length);    
    }    

    // 2. Сортировка с использованием пирамиды    
    for (int i = length - 1; i > 0; i--) {    
        // Меняем корень пирамиды (максимальный элемент) с последним элементом    
        int temp = arr[0];    
        arr[0] = arr[i];    
        arr[i] = temp;    

        // Просеиваем новый корень через уменьшенную пирамиду    
        siftDown(0, i);    
    }    
}    

    // Публичный метод побитовой сортировки
    void bitSort() {
        if (length <= 1) return;
        
        // Находим максимальное значение для определения старшего разряда
        int maxVal = arr[0];
        for (int i = 1; i < length; i++) {
            if (arr[i] > maxVal) {
                maxVal = arr[i];
            }
        }
        
        // Находим номер старшего разряда (k)
        int k = 0;
        while ((1 << (k + 1)) <= maxVal) {
            k++;
        }
        
        // Вызов: l=0, r=n-1, k=номер старшего разряда
        bitSortHelp(0, length - 1, k);
    }

    void bitSortHelp(int l, int r, int k) {
        // 1. Если l ≥ r или k < 0, то выход.
        if (l >= r || k < 0) {
            return;
        }

        // 2. Установка начальных значений: i = l, j = r.
        int i = l;
        int j = r;

        // Создаем маску для проверки k-го разряда (Используем маску!)
        int mask = 1 << k;


        // 3. Пока i ≤ j
        while (i <= j) {
            // 3.1 Пока i ≤ j и в k-ом разряде arr[i] ноль, i++
            while (i <= j && (arr[i] & mask) == 0) {
                i++;
            }

            // 3.2 Пока i ≤ j и в k-ом разряде arr[j] единица, j--
            while (i <= j && (arr[j] & mask) != 0) {
                j--;
            }

            // 3.3 Если i < j, то arr[i] ↔️ arr[j], i++, j--
            if (i < j) {
                int temp = arr[i];
                arr[i] = arr[j];
                arr[j] = temp;
                i++;
                j--;
            }
        }

        // 4. Выполняем эту же процедуру для фрагмента [l, j] по k-1 разряду.
        bitSortHelp(l, j, k - 1);

        // 5. Выполняем эту же процедуру для фрагмента [i, r] по k-1 разряду.
        bitSortHelp(i, r, k - 1);
    }



void shellSort() {    
    int n = length;    
    // Начать с большого шага, затем уменьшить его          
    for (int shag = n / 2; shag > 0; shag /= 2) {    
        // Выполнить сортировку вставками для этого размера шага          
        for (int i = shag; i < n; i += 1) {    
            //сохраним i-элемент для последующей вставки        
            int temp = arr[i]; int j;    
            for (j = i; j >= shag && arr[j - shag] > temp; j -= shag)//смотрим чтобы мы не вылезли за пределы массива(j >= shag) и сравниваем i и j-шаг элементы        
                arr[j] = arr[j - shag];//меняем i и j элементы местами        
            //т.к от j отняли шаг после цикла, то значит мы стоим на том элементе с которым ранее сравнивали и меняем его на i-элемент, если массив отсортирован то замены как таковой не произойдет        
            arr[j] = temp;    
        }    
    }    
}};  
  


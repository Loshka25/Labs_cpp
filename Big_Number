#include <iostream>
#include <cstring>
#include <cstdlib>
#include <ctime>
#include <algorithm>

using namespace std;

typedef unsigned char BASE;
typedef unsigned short DBASE;

#define BASE_SIZE (sizeof(BASE) * 8)
#define BASE_MAX 65536//2 в 16 степени

class BigNumber {
private:
    BASE* coef;
    int len;
    int maxLen;

public:
    BigNumber(int maxLenParam = 1, bool random = false) {
        maxLen = (maxLenParam > 0) ? maxLenParam : 1;
        coef = new BASE[maxLen];

        if (random) {
            len = maxLen;
            for (int i = 0; i < maxLen; i++) {
                coef[i] = rand() % BASE_MAX;//случайная генирация
            }
        }
        else {
            len = 1;
            for (int i = 0; i < maxLen; i++) {
                coef[i] = 0;//заполнение нулями
            }
        }
    }

    BigNumber(const BigNumber& other) {//конструктор копирования 
        maxLen = other.maxLen;
        len = other.len;
        coef = new BASE[maxLen];
        for (int i = 0; i < len; i++) {
            coef[i] = other.coef[i];
        }
    }

    ~BigNumber() {
        delete[] coef;
    }

    BigNumber& operator=(const BigNumber& other) {
        if (this != &other) {//чтобы не удалить самого себя
            delete[] coef;
            maxLen = other.maxLen;
            len = other.len;
            coef = new BASE[maxLen];
            for (int i = 0; i < len; i++) {
                coef[i] = other.coef[i];
            }
        }
        return *this;
    }

    // Вывод в 16 СС(hex)
    string toHex() const {
        if (len == 1 && coef[0] == 0) {
            return "0";//частный случай
        }

        int maxStrLen = len * (BASE_SIZE / 4) + 1;//разбираем каждые 4 hex-цифры
        char* s = new char[maxStrLen];

        int i = 0;//для строки(вперед)
        int j = len - 1;//для каждого раздела(назад)
        int k = BASE_SIZE - 4;//сдвиг на 4 цифры

        bool leadingZero = true;

        while (j >= 0) {
            unsigned int tmp = (coef[j] >> k) & 0xF;//маска 1111

            if (tmp == 0 && leadingZero && j > 0) {//пропускаем ведущие нули
                k -= 4;
                if (k < 0) {
                    k = BASE_SIZE - 4;
                    j--;
                }
                continue;
            }
            leadingZero = false;//всё же нашлось число,а не нуль

            if (0 <= tmp && tmp <= 9) {//переводим его в символ
                s[i] = (char)(tmp + '0');
            }
            else if (10 <= tmp && tmp <= 15) {
                s[i] = (char)(tmp - 10 + 'a');
            }

            i++;
            k -= 4;

            if (k < 0) {
                k = BASE_SIZE - 4;
                j--;
            }
        }

        s[i] = '\0';
        string result(s);
        delete[] s;
        return result;
    }

    // Ввод из hex
    void fromHex(const string& hexStr) {
        const char* s = hexStr.c_str();
        int strLen = strlen(s);

        len = (strLen - 1) / (sizeof(BASE) * 2) + 1;//(длина-1)/4+1
        maxLen = len;

        delete[] coef;
        coef = new BASE[maxLen];
        for (int idx = 0; idx < maxLen; idx++) {
            coef[idx] = 0;
        }

        int j = 0;
        int k = 0;
        int i = strLen - 1;

        while (i >= 0) {
            char c = s[i];
            int tmp = 0;

            if ('0' <= c && c <= '9') {
                tmp = c - '0';
            }
            else if ('a' <= c && c <= 'f') {
                tmp = c - 'a' + 10;
            }
            else if ('A' <= c && c <= 'F') {
                tmp = c - 'A' + 10;
            }
            else {
                i--;
                continue;
            }

            coef[j] |= (BASE)(tmp << k);

            k += 4;
            if (k >= BASE_SIZE) {
                k = 0;
                j++;
            }
            i--;
        }

        while (len > 1 && coef[len - 1] == 0) {//пока ведущие нули
            len--;
        }
    }

    // Операторы ввода/вывода
    friend istream& operator>>(istream& in, BigNumber& num) {
        string hexStr;
        in >> hexStr;
        num.fromHex(hexStr);
        return in;
    }

    friend ostream& operator<<(ostream& out, const BigNumber& num) {
        out << num.toHex();
        return out;
    }

    //#########################################################

    bool operator==(const BigNumber& other) const {
        if (len != other.len) return false;
        for (int i = len - 1; i >= 0; i--) {
            if (coef[i] != other.coef[i]) return false;//сравниваем с старших коэфов,они в массиве в конце
        }
        return true;
    }

    bool operator!=(const BigNumber& other) { return !(*this == other); }

    bool operator<(const BigNumber& other) const {
        if (len != other.len) return len < other.len;
        for (int i = len - 1; i >= 0; i--) {
            if (coef[i] != other.coef[i]) return coef[i] < other.coef[i];
        }
        return false;
    }

    bool operator>(const BigNumber& other) const {
        if (len != other.len) return len > other.len;
        for (int i = len - 1; i >= 0; i--) {
            if (coef[i] != other.coef[i]) return coef[i] > other.coef[i];
        }
        return false;
    }

    bool operator<=(const BigNumber& other) const { return !(*this > other); }
  
    bool operator>=(const BigNumber& other) const { return !(*this < other); }

    //#########################################################
    
    BigNumber& operator+=(const BigNumber& other) {
        int len_u = this->len;
        int len_v = other.len;
        int len_min = (len_u < len_v) ? len_u : len_v;
        int len_max = (len_u > len_v) ? len_u : len_v;

        if (len_max + 1 > this->maxLen) {
            int newMax = len_max + 1;
            BASE* newCoef = new BASE[newMax];
            for (int i = 0; i < len_u; i++) newCoef[i] = this->coef[i];
            for (int i = len_u; i < newMax; i++) newCoef[i] = 0;
            delete[] this->coef;
            this->coef = newCoef;
            this->maxLen = newMax;
        }

        DBASE tmp;
        BASE k = 0;
        int j = 0;

        while (j < len_min) {
            tmp = (DBASE)this->coef[j] + (DBASE)other.coef[j] + k;
            this->coef[j] = (BASE)tmp;
            k = (BASE)(tmp >> BASE_SIZE);
            j++;
        }

       
                while (j < len_v) {
                    tmp = (DBASE)other.coef[j] + k;
                    this->coef[j] = (BASE)tmp;
                    k = (BASE)(tmp >> BASE_SIZE);
                    j++;
                }
            
        
        
            while (j < len_u) {//u длиннее v
                tmp = (DBASE)this->coef[j] + k;
                this->coef[j] = (BASE)tmp;
                k = (BASE)(tmp >> BASE_SIZE);
                j++;
            }
        

        if (k != 0) {// Если после всех разрядов остался перенос, то добавляем новый коэффициент
            this->coef[j] = k;
            this->len = j + 1;
        }
        else {
            this->len = j;
        }

        return *this;
    }

    BigNumber operator+(const BigNumber& other) const {
        BigNumber result = *this;
        result += other;
        return result;
    }

    BigNumber& operator+=(BASE value) {
        BigNumber temp(1);
        temp.coef[0] = value;
        temp.len = 1;
        return *this += temp;
    }

    BigNumber operator+(BASE value) const {
        BigNumber result = *this;
        result += value;
        return result;
    }

    BigNumber& operator-=(const BigNumber& other) {
        if (*this < other) {//так как работаем с неотрицательными, то при случае вычитания из меньшего большее возвращаем ноль
            this->len = 1;
            this->coef[0] = 0;
            return *this;
        }

        DBASE tmp;
        BASE k = 0;
        int j = 0;

        //Вычитаем общие разряды
        while (j < other.len) {
            tmp = ((DBASE)1 << BASE_SIZE) | this->coef[j];
            tmp = tmp - other.coef[j] - k;
            this->coef[j] = (BASE)tmp;
            k = (BASE)(!(tmp >> BASE_SIZE));//смотрим был ли займ
            j++;
        }

        //Если у текущего числа остались старшие разряды — обрабатываем их с учётом займа
        if (j < this->len) {
            while (j < this->len) {
                tmp = ((DBASE)1 << BASE_SIZE) | this->coef[j];
                tmp = tmp - k;
                this->coef[j] = (BASE)tmp;
                k = (BASE)(!(tmp >> BASE_SIZE));
                j++;
            }
        }

        //Убираем ведущие нули
        while (this->len > 1 && this->coef[this->len - 1] == 0) {
            this->len--;
        }

        return *this;
    }

    BigNumber operator-(const BigNumber& other) const {
        BigNumber result = *this;
        result -= other;
        return result;
    }

    BigNumber& operator-=(BASE value) {
        BigNumber temp(1);
        temp.coef[0] = value;
        temp.len = 1;
        return *this -= temp;
    }

    BigNumber operator-(BASE value) const {
        BigNumber result = *this;
        result -= value;
        return result;
    }
    //#########################################################
    BigNumber& operator*=(BASE value) {
        if (value == 0) {
            len = 1;
            coef[0] = 0;
            return *this;
        }
        if (value == 1) {
            return *this;
        }

        // Проверяем, хватит ли памяти (результат может быть на 1 цифру длиннее)
        if (len + 1 > maxLen) {
            int newMax = len + 1;
            BASE* newCoef = new BASE[newMax]();
            for (int i = 0; i < len; i++) newCoef[i] = coef[i];
            delete[] coef;
            coef = newCoef;
            maxLen = newMax;
        }

        DBASE tmp;
        BASE k = 0;  // Перенос

        for (int j = 0; j < len; j++) {
            // Умножаем текущую цифру на value + перенос
            tmp = (DBASE)coef[j] * (DBASE)value + k;
            coef[j] = (BASE)tmp;
            k = (BASE)(tmp >> BASE_SIZE);//перенос
        }

        // Если остался перенос, добавляем новую цифру
        if (k != 0) {
            coef[len] = k;
            len++;
        }

        return *this;
    }

    BigNumber operator*(BASE value) const {
        BigNumber result = *this;
        result *= value;
        return result;
    }

    BigNumber& operator*=(const BigNumber& other) {
        if (other.len == 1 && other.coef[0] == 0) {
            len = 1;
            coef[0] = 0;
            return *this;
        }

        if (other.len == 1 && other.coef[0] == 1) {
            return *this;
        }

        int newLen = this->len + other.len;
        BASE* tempCoef = new BASE[newLen];//массив-результат
        for (int i = 0; i < newLen; i++) {
            tempCoef[i] = 0;
        }

        DBASE tmp;
        BASE k;

        for (int j = 0; j < other.len; j++) {
            if (other.coef[j] == 0) continue;//пока во втором(нижнем) числе нули, то пропускаем

            k = 0;

            for (int i = 0; i < this->len; i++) {//проходимся по всем цифрам первого числа
                // w[i+j] += u[i] * v[j] + k
                tmp = (DBASE)this->coef[i] * (DBASE)other.coef[j] + tempCoef[i + j] + k;
                //к-перенос,temp[i+j]-число, которое ранее в процессе умножения могло попасть в этот разряд

                tempCoef[i + j] = (BASE)tmp;
                k = (BASE)(tmp >> BASE_SIZE);
            }

            // Если остался перенос, записываем его
            if (k != 0) {
                tempCoef[this->len + j] = k;
            }
        }
        

        // Обновляем текущий объект
        delete[] coef;
        coef = tempCoef;
        maxLen = newLen;
        len = newLen;
        while (len > 1 && coef[len - 1] == 0) {
            len--;
        }
        return *this;
    }

    BigNumber operator*(const BigNumber& other) const {
        BigNumber result = *this;
        result *= other;
        return result;
    }
    // Деление на цифру
    BigNumber& operator/=(BASE divisor) {
        if (divisor == 0) {
            len = 1;
            coef[0] = 0;
            return *this;//вернуть ошибку
        }

        DBASE tmp;
        DBASE r = 0;  // Остаток

        // Идем от старшего разряда к младшему
        for (int j = len - 1; j >= 0; j--) {
            // tmp = r * BASE + u_j 
            tmp = (r << BASE_SIZE) | coef[j];

            // Вычисляем цифру частного
            coef[j] = (BASE)(tmp / divisor);

            // Вычисляем новый остаток
            r = tmp % divisor;
        }

        while (len > 1 && coef[len - 1] == 0) {
            len--;
        }

        return *this;
    }

    BigNumber operator/(BASE divisor) const {
        BigNumber result = *this;
        result /= divisor;
        return result;
    }

    // Остаток от деления на цифру
    BASE operator%(BASE divisor) const {
        if (divisor == 0) return 0;

        DBASE tmp;
        DBASE r = 0;

        for (int j = len - 1; j >= 0; j--) {
            tmp = (r << BASE_SIZE) | coef[j];
            r = tmp % divisor;
        }


        return (BASE)r;
    }

    BigNumber& operator%=(BASE divisor) {
        BASE rem = *this % divisor;
        len = 1;
        coef[0] = rem;
        return *this;
    }

    //#########################################################

    int getLen() const { return len; }
    int getMaxLen() const { return maxLen; }

    BASE getCoeff(int index) const {
        if (index >= 0 && index < len) return coef[index];
        return 0;
    }
};


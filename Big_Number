    cout << "=== Тестирование BigNumber ===" << endl;
    cout << "BASE_SIZE = " << BASE_SIZE << " бит" << endl;
    cout << endl;

    // 1. Конструкторы
    cout << "1) КОНСТРУКТОРЫ:" << endl;
    BigNumber a;
    cout << "a = " << a << endl;

    BigNumber b(5);
    cout << "b = " << b << endl;

    BigNumber c(3, true);
    cout << "c = " << c << " (random)" << endl;

    BigNumber d = c;
    cout << "d = " << d << " (копия c)" << endl;
    cout << endl;

    // 2. Ввод от пользователя
    cout << "2) ВВОД ОТ ПОЛЬЗОВАТЕЛЯ:" << endl;
    BigNumber num1;
    cout << "Введите первое число (hex): ";
    cin >> num1;
    cout << "Вы ввели: " << num1 << endl;

    BigNumber num2;
    cout << "Введите второе число (hex): ";
    cin >> num2;
    cout << "Вы ввели: " << num2 << endl;
    cout << endl;

    // 3. Операции
    cout << "3) РЕЗУЛЬТАТЫ:" << endl;
    cout << num1 << " + " << num2 << " = " << (num1 + num2) << endl;

    if (num1 >= num2) {
        cout << num1 << " - " << num2 << " = " << (num1 - num2) << endl;
    }
    else {
        cout << num1 << " < " << num2 << " (вычитание не выполнено)" << endl;
    }

    return 0;
}

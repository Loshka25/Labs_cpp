    cout << endl;
    cout << ((num1 * num3) / num3) << endl;
    cout << ((num1 / num3) * num3 + (num1 % num3)) << endl;
    cout << ((num1 / num3) * num3 +(num1 % num3)) << endl;
    return 0;
